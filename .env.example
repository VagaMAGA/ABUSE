# ── Vercel → Project → Environment Variables ──
# Add each row below. Scope: Production + Preview + Development.

# Required — canonical URLs (Farcaster manifest, OG, share links)
NEXT_PUBLIC_SITE_URL=https://abuse-iota.vercel.app

# Required — leaderboard + referrals API (get free key: alchemy.com or infura.io)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Required — rank badge mint signatures (private key for rank signer wallet)
# Must match BadgeNFT.rankSigner on-chain: 0x1261bc5b8A3CEEe9D17a1Fd0d57a6D34bF48B81a
# Format: 0x + 64 hex chars (no quotes/spaces in Vercel UI)
BADGE_RANK_SIGNER_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY

# Optional — faster leaderboard indexing (default 46725882 is in src/config/contract.ts)
# HUB_DEPLOY_FROM_BLOCK=46725882

# Optional — override builder code (default bc_09jqcvbo in src/config/app.ts)
# NEXT_PUBLIC_BASE_BUILDER_CODE=bc_09jqcvbo

# ── Local dev only ──
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Never add to Vercel (local deploy / verify only) ──
# PRIVATE_KEY=0x...
# ETHERSCAN_API_KEY=...

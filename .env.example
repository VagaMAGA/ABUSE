# ── Production (Vercel) — copy to Vercel Environment Variables ──

NEXT_PUBLIC_SITE_URL=https://abuse-iota.vercel.app

# Rank badge signatures (wallet used as rank signer)
BADGE_RANK_SIGNER_PRIVATE_KEY=0xYOUR_RANK_SIGNER_PRIVATE_KEY

# Leaderboard + on-chain reads (Alchemy / Infura recommended)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional overrides (defaults in src/config/)
# NEXT_PUBLIC_BASE_BUILDER_CODE=bc_your_code
# HUB_DEPLOY_FROM_BLOCK=46725882

# ── Local dev ──
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contract deploy (Foundry, local machine only)
# PRIVATE_KEY=0x...
# BASESCAN_API_KEY=your_key_from_https://etherscan.io/myapikey
